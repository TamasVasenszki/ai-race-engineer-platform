# Copy to terraform.tfvars and adjust as needed. All values have defaults; override only what you need.
# terraform.tfvars is gitignored.
#
# Prerequisites — run the bootstrap config first to create the S3 + DynamoDB backend:
#   cd infra/terraform/bootstrap && terraform init && terraform apply
# Then come back here:
#   cd infra/terraform && terraform init

# region       = "eu-central-1"
# project_name = "ai-race-engineer"
# vpc_cidr     = "10.0.0.0/16"
# github_repo  = "TamasVasenszki/ai-race-engineer-platform"

# EKS:
# cluster_version     = "1.36"   # override if unavailable in the region at apply time
# node_instance_types = ["t3.medium"]
# node_desired_size   = 3   # 3 fits the observability stack (Prometheus/Grafana + Loki/Promtail)
# node_min_size       = 2
# node_max_size       = 4

# Database (defaults are the cheapest sensible options):
# db_instance_class = "db.t4g.micro"
# db_name           = "race_engineer"
# db_username       = "race"

# AI provider (default: mock — no API key needed):
# ai_provider       = "mock"
# anthropic_api_key = ""    # set for ai_provider=claude
# openai_api_key    = ""    # set for ai_provider=openai
