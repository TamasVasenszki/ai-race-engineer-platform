# AI Provider: mock | claude | openai | ollama
AI_PROVIDER=mock

# Anthropic (csak ha AI_PROVIDER=claude)
ANTHROPIC_API_KEY=

# OpenAI (csak ha AI_PROVIDER=openai)
OPENAI_API_KEY=

# Ollama (opcionális, default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Database
DATABASE_URL=postgresql+asyncpg://race:race@localhost:5433/race_engineer
