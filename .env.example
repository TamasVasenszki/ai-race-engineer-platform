# AI Provider: mock | claude | openai | ollama
AI_PROVIDER=mock

# Anthropic (only when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=

# OpenAI (only when AI_PROVIDER=openai)
OPENAI_API_KEY=

# Ollama (only when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# For better quality with 16GB+ RAM: OLLAMA_MODEL=llama3.1:8b
# Docker Compose overrides OLLAMA_BASE_URL to http://ollama:11434 automatically.

# Database
DATABASE_URL=postgresql+asyncpg://race:race@localhost:5433/race_engineer

# --- Offline mode preset ---
# To run fully offline with a local LLM, set:
#   AI_PROVIDER=ollama
#   OLLAMA_MODEL=llama3.2
# Then: docker compose --profile ollama up
# First run requires internet to pull the model: docker exec -it <ollama-container> ollama pull llama3.2
